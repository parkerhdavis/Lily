{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Lily",
	"version": "0.1.0",
	"identifier": "com.carelaw.lily",
	"build": {
		"devUrl": "http://localhost:5173",
		"frontendDist": "../frontend/dist"
	},
	"app": {
		"windows": [
			{
				"title": "Lily — Document Drafting",
				"width": 1200,
				"height": 800,
				"minWidth": 900,
				"minHeight": 600,
				"resizable": true
			}
		],
		"security": {
			"csp": null,
			"capabilities": [
				{
					"identifier": "main-capability",
					"windows": ["*"],
					"permissions": [
						"dialog:allow-open",
						"dialog:allow-save",
						"fs:allow-read-text-file",
						"fs:allow-write-text-file",
						"fs:allow-read-file",
						"fs:allow-write-file",
						"fs:allow-exists",
						"fs:allow-read-dir",
						"fs:allow-mkdir",
						"fs:allow-copy-file",
						{
							"identifier": "fs:scope",
							"allow": [
								"$DOWNLOAD/**",
								"$DOCUMENT/**",
								"$DESKTOP/**",
								"$HOME/**"
							]
						},
						"core:path:allow-resolve-directory"
					]
				}
			]
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
